# ============================================
# Configuración de Meteorológico (COPEC)
# Copia este archivo como .env para desarrollo local
# ============================================

PORT=3000

# Coordenadas por defecto (se usan cuando no se puede detectar IP)
# COPEC Catemu (ejemplo)
DEFAULT_LAT=-32.789522
DEFAULT_LON=-70.958934

# Intervalo de actualización de datos (en milisegundos)
# 5 minutos = 300000 ms
UPDATE_INTERVAL_MS=300000

# Entorno (production en Render)
NODE_ENV=development

# ============================================
# API Key de Open-Meteo (OPCIONAL pero RECOMENDADO en producción)
# Evita problemas de rate limiting en IPs compartidas (Render, Railway, etc.)
# Regístrate gratis en: https://open-meteo.com/en/members
# OPEN_METEO_API_KEY=tu_api_key_aqui

